# Copy to .env and fill in values

# Port the backend listens on
PORT=3001

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs allowed to add tasks.
# Leave blank to allow any chat (not recommended for public bots).
# Find your chat ID by messaging @userinfobot
ALLOWED_CHAT_IDS=

# Name to strip from the start of messages (case-insensitive)
TARGET_NAME=Oli
